#!/usr/bin/env node

// Generates sector arc and leg line geometries from LIGHTS features in a GeoJSON file.
//
// Usage: bin/generate-sector-arcs <lights.geojson> <output.geojson> [--minzoom N] [--maxzoom N]
//
// Reads LIGHTS point features with SECTR1/SECTR2 attributes and produces
// LineString features for:
//   - Sector arcs (colored arcs between the two bearings)
//   - Sector leg lines (dashed lines from the light outward at each bearing)
//
// The output layer is named _LIGHTS_SECTORS and is consumed by the MapLibre
// style generated by the LIGHTS06 CSP.

import { readFileSync, writeFileSync } from "fs";

const args = process.argv.slice(2);
let inputPath, outputPath;
let minzoom = 0,
  maxzoom = 16;

// Parse args
const positional = [];
for (let i = 0; i < args.length; i++) {
  if (args[i] === "--minzoom" && args[i + 1]) {
    minzoom = parseInt(args[++i]);
  } else if (args[i] === "--maxzoom" && args[i + 1]) {
    maxzoom = parseInt(args[++i]);
  } else {
    positional.push(args[i]);
  }
}
inputPath = positional[0];
outputPath = positional[1];

if (!inputPath || !outputPath) {
  console.error(
    "Usage: generate-sector-arcs <lights.geojson> <output.geojson> [--minzoom N] [--maxzoom N]",
  );
  process.exit(1);
}

// Screen mm to geographic degrees conversion.
// At a given zoom level, 1 pixel ≈ C * cos(lat) / (2^zoom * tileSize).
// We convert mm to pixels (1mm ≈ 96/25.4 px at standard DPI), then to degrees.
const TILE_SIZE = 512;
const EARTH_CIRCUMFERENCE = 2 * Math.PI * 6378137; // meters

function mmToMeters(mm, zoom, lat) {
  // pixels per mm at standard screen DPI (96)
  const pxPerMm = 96 / 25.4;
  const px = mm * pxPerMm;
  // meters per pixel at this zoom and latitude
  const metersPerPx =
    (EARTH_CIRCUMFERENCE * Math.cos((lat * Math.PI) / 180)) /
    (Math.pow(2, zoom) * TILE_SIZE);
  return px * metersPerPx;
}

function metersToDegreesLon(meters, lat) {
  return (
    meters / ((EARTH_CIRCUMFERENCE / 360) * Math.cos((lat * Math.PI) / 180))
  );
}

function metersToDegreesLat(meters) {
  return meters / (EARTH_CIRCUMFERENCE / 360);
}

// Flip a bearing from seaward to from-light (add 180, normalize to [0, 360))
function flipBearing(bearing) {
  return (((bearing + 180) % 360) + 360) % 360;
}

// Generate arc LineString as an array of [lon, lat] points
function generateArc(center, radiusMeters, startBearing, endBearing, steps) {
  const [lon, lat] = center;
  // Ensure endBearing > startBearing for clockwise sweep
  if (endBearing <= startBearing) endBearing += 360;

  const points = [];
  for (let i = 0; i <= steps; i++) {
    const bearing = startBearing + (endBearing - startBearing) * (i / steps);
    const bearingRad = (bearing * Math.PI) / 180;
    // Bearing: 0=north, 90=east
    const dLat = radiusMeters * Math.cos(bearingRad);
    const dLon = radiusMeters * Math.sin(bearingRad);
    points.push([
      lon + metersToDegreesLon(dLon, lat),
      lat + metersToDegreesLat(dLat),
    ]);
  }
  return points;
}

// Generate a leg line from center outward at a bearing
function generateLeg(center, lengthMeters, bearing) {
  const [lon, lat] = center;
  const bearingRad = (bearing * Math.PI) / 180;
  const dLat = lengthMeters * Math.cos(bearingRad);
  const dLon = lengthMeters * Math.sin(bearingRad);
  return [
    [lon, lat],
    [lon + metersToDegreesLon(dLon, lat), lat + metersToDegreesLat(dLat)],
  ];
}

// Determine the S-52 colour token from COLOUR attribute
// COLOUR is a comma-separated string of S-57 colour codes
function sectorColourToken(colour) {
  if (!colour) return "CHMGD";
  const codes = String(colour).split(",").map(Number);
  const has = (v) => codes.includes(v);

  if (has(1) && has(3)) return "LITRD"; // white+red
  if (has(3)) return "LITRD"; // red
  if (has(1) && has(4)) return "LITGN"; // white+green
  if (has(4)) return "LITGN"; // green
  if (has(11)) return "LITYW"; // orange
  if (has(6)) return "LITYW"; // yellow
  if (has(1)) return "LITYW"; // white
  return "CHMGD"; // default magenta
}

// Determine if arc should use dashed style (LITVIS 3=faint, 7=obscured, 8=partially obscured)
function isFaintOrObscured(litvis) {
  if (!litvis) return false;
  const codes = String(litvis).split(",").map(Number);
  return codes.some((v) => v === 3 || v === 7 || v === 8);
}

// Main
const input = JSON.parse(readFileSync(inputPath, "utf8"));
const features = [];

// Use maxzoom for radius calculation — this produces arcs that are the correct
// 20mm screen size at the chart's most detailed zoom level. At lower zooms the
// arcs appear smaller, but SCAMIN filtering hides them at those scales anyway.
const targetZoom = maxzoom;

for (const feature of input.features) {
  if (!feature.geometry || feature.geometry.type !== "Point") continue;

  const props = feature.properties || {};
  const sectr1 = props.SECTR1;
  const sectr2 = props.SECTR2;

  // Directional lights (CATLIT 1 or 16) with ORIENT: generate a bearing line
  const catlit = String(props.CATLIT || "")
    .split(",")
    .map(Number);
  const isDirectional =
    (catlit.includes(1) || catlit.includes(16)) &&
    props.ORIENT != null &&
    !catlit.includes(8) &&
    !catlit.includes(9) &&
    !catlit.includes(11);

  if (isDirectional) {
    const center = feature.geometry.coordinates;
    const lat = center[1];
    const bearing = flipBearing(props.ORIENT);
    // Use VALNMR (nominal range in NM) if available, otherwise 25mm screen equivalent
    const lengthMeters =
      props.VALNMR != null
        ? props.VALNMR * 1852
        : mmToMeters(25, targetZoom, lat);

    const common = {
      ...(props.LNAM != null && { LNAM: props.LNAM }),
      ...(props.SCAMIN != null && { SCAMIN: props.SCAMIN }),
      ...(props.INTU != null && { INTU: props.INTU }),
    };

    features.push({
      type: "Feature",
      geometry: {
        type: "LineString",
        coordinates: generateLeg(center, lengthMeters, bearing),
      },
      properties: {
        ...common,
        _type: "leg",
      },
    });
  }

  if (sectr1 == null || sectr2 == null) continue;

  // "No sector" test: both 0, or difference is 0 or 360
  const diff = Math.abs(sectr2 - sectr1);
  if (diff === 0 || diff === 360) continue;

  const center = feature.geometry.coordinates;
  const lat = center[1];

  // Flip bearings from seaward to from-light
  const leg1Bearing = flipBearing(sectr1);
  const leg2Bearing = flipBearing(sectr2);

  // Arc radius: 20mm default (extended to 25mm handled later via co-location detection)
  const arcRadiusMm = props._EXTENDED_ARC ? 25 : 20;
  const arcRadiusMeters = mmToMeters(arcRadiusMm, targetZoom, lat);

  // Leg length: 25mm default
  const legLengthMm = 25;
  const legLengthMeters = mmToMeters(legLengthMm, targetZoom, lat);

  // Arc sweep: number of steps proportional to arc size
  let arcStart = leg1Bearing;
  let arcEnd = leg2Bearing;
  if (arcEnd <= arcStart) arcEnd += 360;
  const arcDegrees = arcEnd - arcStart;
  const steps = Math.max(8, Math.ceil(arcDegrees / 3));

  const colourToken = sectorColourToken(props.COLOUR);
  const obscured = isFaintOrObscured(props.LITVIS);

  // Common properties carried through to tiles
  const common = {
    ...(props.LNAM != null && { LNAM: props.LNAM }),
    ...(props.SCAMIN != null && { SCAMIN: props.SCAMIN }),
    ...(props.INTU != null && { INTU: props.INTU }),
  };

  // Arc feature (OUTLW underlay is handled by having two style layers)
  features.push({
    type: "Feature",
    geometry: {
      type: "LineString",
      coordinates: generateArc(
        center,
        arcRadiusMeters,
        arcStart,
        arcEnd,
        steps,
      ),
    },
    properties: {
      ...common,
      _type: "arc",
      _colour: colourToken,
      _style: obscured ? "DASH" : "SOLD",
    },
  });

  // Leg 1
  features.push({
    type: "Feature",
    geometry: {
      type: "LineString",
      coordinates: generateLeg(center, legLengthMeters, leg1Bearing),
    },
    properties: {
      ...common,
      _type: "leg",
    },
  });

  // Leg 2
  features.push({
    type: "Feature",
    geometry: {
      type: "LineString",
      coordinates: generateLeg(center, legLengthMeters, leg2Bearing),
    },
    properties: {
      ...common,
      _type: "leg",
    },
  });
}

const output = {
  type: "FeatureCollection",
  features,
};

writeFileSync(outputPath, JSON.stringify(output));
console.error(
  `Generated ${features.length} sector features (${features.filter((f) => f.properties._type === "arc").length} arcs, ${features.filter((f) => f.properties._type === "leg").length} legs)`,
);
